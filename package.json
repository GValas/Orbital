{
  "name": "orbital",
  "version": "1.0.0",
  "description": "Interactive N-body solar system simulator with a parametric physics dashboard.",
  "type": "module",
  "scripts": {
    "build": "node build.ts",
    "typecheck": "tsc --noEmit",
    "serve": "node build.ts && python3 -m http.server 8000 --directory dist",
    "deploy": "bash deploy.sh"
  },
  "engines": {
    "node": ">=22.13"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "@types/node": "^22.0.0"
  }
}
